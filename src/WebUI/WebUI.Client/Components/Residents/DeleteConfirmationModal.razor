@using Domain.Entities
@* DeleteConfirmationModal.razor: Modal dialog for confirming resident deletion *@

@if (Show && ResidentToDelete is not null)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="deleteModalLabel"
         style="background:rgba(0,0,0,.5);">
        <div class="modal-dialog modal-sm" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteModalLabel">Slet beboer</h5>
                    <button type="button" class="btn-close" @onclick="OnCancel" aria-label="Luk"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(DeleteError))
                    {
                        <div class="alert alert-danger py-2">@DeleteError</div>
                    }
                    <p>
                        Er du sikker på, at du vil slette beboer
                        <strong>@ResidentToDelete.FirstName @ResidentToDelete.LastName</strong>?
                    </p>
                    <p class="text-danger small mb-0">Denne handling kan ikke fortrydes.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" @onclick="OnCancel"
                            disabled="@IsSaving">
                        Annuller
                    </button>
                    <button type="button" class="btn btn-danger btn-sm" @onclick="OnDelete"
                            disabled="@IsSaving">
                        @if (IsSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        }
                        Slet
                    </button>
                </div>
            </div>
        </div>
    </div>
}
