
@page "/"

@rendermode InteractiveAuto

<PageTitle>Home</PageTitle>

<h1>Hello, world!</h1>

<AuthorizeView>
  <Authorizing>
    <p>Checking authentication status...</p>
  </Authorizing>
  <Authorized>
    <p>You are logged in.</p>
    <p><b>User:</b> @user?.Identity?.Name</p>
    <ul>
      @if (user != null)
      {
        foreach (var claim in user.Claims)
        {
          <li>@claim.Type: @claim.Value</li>
        }
      }
    </ul>
    <button @onclick="Logout">Logout</button>
    <span class="nav" >
      <NavLink href="/residents">Manage residents</NavLink>
    </span>
  </Authorized>
  <NotAuthorized>
    @if (isInteractive)
    {
      <RedirectToLogin/>
    }
    else
    {
      <span>
        <LoadingSpinner />
      </span>
    }
  </NotAuthorized>
</AuthorizeView>
