@* UC-010 - Anonymization Queue (Admin only) *@

@page "/admin/gdpr/anonymization"
@rendermode InteractiveAuto
@* @attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "admin")] *@

@using Core.DTOs.Anonymization
@using Domain.Enums

<PageTitle>Anonymization Queue</PageTitle>
<AuthorizeView Roles="admin">
  <Authorized>
    <main class="container mt-4">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
          <li class="breadcrumb-item"><a href="/admin/gdpr">GDPR</a></li>
          <li class="breadcrumb-item active" aria-current="page">Anonymization Queue</li>
        </ol>
      </nav>

      <h1 class="mb-4">Anonymization Queue</h1>
      <p class="text-muted mb-4">
        Review residents whose data has reached the retention threshold. MedicineLogs are pseudonymized
        rather than fully anonymized per Autorisationsloven §22.
      </p>

      @if (!string.IsNullOrEmpty(_feedbackMessage))
      {
        <div class="alert @_feedbackClass alert-dismissible fade show" role="alert">
          @_feedbackMessage
          <button type="button" class="btn-close" @onclick="ClearFeedback"></button>
        </div>
      }

      @if (_isLoading)
      {
        <div class="text-center my-5">
          <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
          </div>
        </div>
      }
      else if (_candidates.Count == 0)
      {
        <div class="alert alert-info">
          ✅ No anonymization candidates pending review.
        </div>
      }
      else
      {
        <div class="table-responsive">
          <table class="table table-striped align-middle">
            <thead>
              <tr>
                <th>Resident ID</th>
                <th>Suggested At</th>
                <th>Reason</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              @foreach (AnonymizationCandidateDto candidate in _candidates)
              {
                <tr>
                  <td><code>@candidate.ResidentId.ToString()[..8]…</code></td>
                  <td>@candidate.SuggestedAt.ToString("yyyy-MM-dd HH:mm")</td>
                  <td>@candidate.Reason</td>
                  <td>
                    <span class="badge @GetStatusBadgeClass(candidate.Status)">@candidate.Status</span>
                  </td>
                  <td>
                    @if (candidate.Status == AnonymizationStatus.Pending)
                    {
                      @if (_confirmingCandidateId == candidate.Id)
                      {
                        <div class="d-flex gap-2 align-items-center">
                          <small class="text-warning">Confirm anonymization?</small>
                          <button class="btn btn-sm btn-success" @onclick="() => ConfirmApproveAsync(candidate.Id)">Yes, approve</button>
                          <button class="btn btn-sm btn-secondary" @onclick="CancelConfirm">Cancel</button>
                        </div>
                      }
                      else if (_rejectingCandidateId == candidate.Id)
                      {
                        <div class="d-flex gap-2 align-items-center">
                          <input type="text" class="form-control form-control-sm" @bind="_rejectReason" placeholder="Reason for rejection" />
                          <button class="btn btn-sm btn-danger" @onclick="() => ConfirmRejectAsync(candidate.Id)">Reject</button>
                          <button class="btn btn-sm btn-secondary" @onclick="CancelConfirm">Cancel</button>
                        </div>
                      }
                      else
                      {
                        <button class="btn btn-sm btn-success me-1" @onclick="() => StartApprove(candidate.Id)">Approve</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => StartReject(candidate.Id)">Reject</button>
                      }
                    }
                    else
                    {
                      <span class="text-muted">No action available</span>
                    }
                  </td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      }
    </main>
  </Authorized>
</AuthorizeView>
