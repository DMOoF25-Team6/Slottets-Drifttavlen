@* UC-014 - Administration: Create, Read, Update and Delete Residents *@

@layout DashboardLayout
@page "/residents"
@rendermode InteractiveAuto
@using Domain.Enums
@using WebUI.Client.Components.Layout

<PageTitle>Beboere</PageTitle>

<section aria-label="Residents administration" class="container-fluid p-3">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Beboere</h2>
        <div class="d-flex gap-2">
            @if (CanManageCurrentDepartment)
            {
                <button type="button" class="btn btn-primary btn-sm" @onclick="OpenCreateModal">
                    + Opret beboer
                </button>
            }
            <a href="/dashboard" class="btn btn-outline-secondary btn-sm">
                &larr; Tilbage til dashboard
            </a>
        </div>
    </div>

    @* ── Department filter tabs ── *@
    <ul class="nav nav-tabs mb-3" role="tablist">
        @foreach (var dept in DepartmentOptions)
        {
            <li class="nav-item" role="presentation">
                <button class="nav-link @(dept == _selectedDepartment ? "active" : "")"
                        type="button" role="tab"
                        @onclick="() => SelectDepartment(dept)">
                    @dept
                </button>
            </li>
        }
    </ul>

    @if (_isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Indlæser...</span>
            </div>
        </div>
    }
    else if (_hasError)
    {
        <div class="alert alert-danger" role="alert">
            Der opstod en fejl ved indlæsning af beboere. Prøv igen.
            <button type="button" class="btn btn-sm btn-outline-danger ms-2" @onclick="LoadResidentsAsync">Genindlæs</button>
        </div>
    }
    else if (!FilteredResidents.Any())
    {
        <div class="alert alert-info" role="alert">
            Ingen beboere fundet i <strong>@_selectedDepartment</strong>. Opret den første beboer ved at klikke på "Opret beboer".
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Initialer</th>
                        <th>Fornavn</th>
                        <th>Efternavn</th>
                        <th>Trafiklys</th>
                        <th class="text-end">Handlinger</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var resident in FilteredResidents)
                    {
                        <tr>
                            <td><code>@resident.Initials</code></td>
                            <td>@resident.FirstName</td>
                            <td>@resident.LastName</td>
                            <td>
                                @if (resident.TrafficLightStatus.HasValue)
                                {
                                    <span class="badge @GetTrafficLightBadgeClass(resident.TrafficLightStatus.Value)">
                                        @GetTrafficLightLabel(resident.TrafficLightStatus.Value)
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (CanManageResident(resident))
                                {
                                    <button type="button" class="btn btn-outline-primary btn-sm me-1"
                                            @onclick="() => OpenEditModal(resident)">
                                        Rediger
                                    </button>
                                    <button type="button" class="btn btn-outline-danger btn-sm"
                                            @onclick="() => OpenDeleteConfirm(resident)">
                                        Slet
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</section>

@* ── Create / Edit Modal ── *@
@if (_showFormModal)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="residentModalLabel"
         style="background:rgba(0,0,0,.5);">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="residentModalLabel">@(_isEditing ? "Rediger beboer" : "Opret beboer")</h5>
                    <button type="button" class="btn-close" @onclick="CloseFormModal" aria-label="Luk"></button>
                </div>
                <EditForm Model="_formModel" OnValidSubmit="HandleFormSubmitAsync">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        @if (_formError is not null)
                        {
                            <div class="alert alert-danger py-2">@_formError</div>
                        }
                        <div class="mb-3">
                            <label for="initials" class="form-label">Initialer <span class="text-danger">*</span></label>
                            <InputText id="initials" class="form-control" @bind-Value="_formModel.Initials"
                                       maxlength="2" placeholder="f.eks. AB" />
                            <ValidationMessage For="() => _formModel.Initials" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label for="firstName" class="form-label">Fornavn <span class="text-danger">*</span></label>
                            <InputText id="firstName" class="form-control" @bind-Value="_formModel.FirstName"
                                       placeholder="Fornavn" />
                            <ValidationMessage For="() => _formModel.FirstName" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label for="lastName" class="form-label">Efternavn <span class="text-danger">*</span></label>
                            <InputText id="lastName" class="form-control" @bind-Value="_formModel.LastName"
                                       placeholder="Efternavn" />
                            <ValidationMessage For="() => _formModel.LastName" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label for="department" class="form-label">Afdeling <span class="text-danger">*</span></label>
                            <InputSelect id="department" class="form-select" @bind-Value="_formModel.Department">
                                <option value="@Department.Slottet">Slottet</option>
                                <option value="@Department.Skoven">Skoven</option>
                                <option value="@Department.Marken">Marken</option>
                            </InputSelect>
                            <ValidationMessage For="() => _formModel.Department" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label for="trafficLight" class="form-label">Trafiklys</label>
                            <InputSelect id="trafficLight" class="form-select" @bind-Value="_formModel.TrafficLightStatus">
                                <option value="">— Vælg status —</option>
                                <option value="@TrafficLightStatus.Green">Grøn</option>
                                <option value="@TrafficLightStatus.Yellow">Gul</option>
                                <option value="@TrafficLightStatus.Red">Rød</option>
                            </InputSelect>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseFormModal"
                                disabled="@_isSaving">
                            Annuller
                        </button>
                        <button type="submit" class="btn btn-primary" disabled="@_isSaving">
                            @if (_isSaving)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                            }
                            @(_isEditing ? "Gem ændringer" : "Opret")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@* ── Delete Confirmation Modal ── *@
@if (_showDeleteModal && _residentToDelete is not null)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="deleteModalLabel"
         style="background:rgba(0,0,0,.5);">
        <div class="modal-dialog modal-sm" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteModalLabel">Slet beboer</h5>
                    <button type="button" class="btn-close" @onclick="CloseDeleteModal" aria-label="Luk"></button>
                </div>
                <div class="modal-body">
                    @if (_deleteError is not null)
                    {
                        <div class="alert alert-danger py-2">@_deleteError</div>
                    }
                    <p>
                        Er du sikker på, at du vil slette beboer
                        <strong>@_residentToDelete.FirstName @_residentToDelete.LastName</strong>?
                    </p>
                    <p class="text-danger small mb-0">Denne handling kan ikke fortrydes.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" @onclick="CloseDeleteModal"
                            disabled="@_isSaving">
                        Annuller
                    </button>
                    <button type="button" class="btn btn-danger btn-sm" @onclick="HandleDeleteAsync"
                            disabled="@_isSaving">
                        @if (_isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        }
                        Slet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

