@page "/login"
@rendermode InteractiveAuto
@using Microsoft.AspNetCore.Components.Authorization

<div class="container mt-5 d-flex justify-content-center flex-column align-items-center gap-4">

    <div class="card shadow" style="min-width: 350px; max-width: 400px; width: 100%;">
        <div class="card-body">
            <h3 class="card-title text-center mb-4">Log ind</h3>
            <EditForm Model="loginModel" OnValidSubmit="HandleLogin" Context="editFormContext" FormName="LoginFormName">
                <DataAnnotationsValidator />
                <ValidationSummary class="mb-3" />
                <div class="mb-3">
                    <label class="form-label">Brugernavn:</label>
                    <InputText @bind-Value="loginModel.Username" class="form-control" />
                </div>

               <div class="mb-3">
                    <label class="form-label">Adgangskode:</label>
                    <InputText @bind-Value="loginModel.Password" type="password" class="form-control" />
                </div>
                <button type="submit" class="btn btn-primary w-100">Log ind</button>
            </EditForm>
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="text-danger mt-3">@errorMessage</div>
            }
        </div>
    </div>

@if (IsDebug)
{
    @* ── Debug quick-login panel (only shown in DEBUG builds) ── *@
    <div class="card shadow border-warning" style="min-width: 350px; max-width: 500px; width: 100%;">
        <div class="card-header bg-warning text-dark fw-bold">
            🛠 Debug – hurtig login
        </div>
        <div class="card-body p-2">
            <p class="small text-muted mb-2">Klik på en medarbejder for at udfylde login-formularen.</p>
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Navn</th>
                        <th>Rolle</th>
                        <th>Claims</th>
                        <th>Afdeling</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in DebugEmployees)
                    {
                        <tr role="button" style="cursor:pointer" @onclick="() => AutoFill(emp)">
                            <td>@emp.Name</td>
                            <td><span class="badge bg-secondary">@emp.Role</span></td>
                            <td>
                                @foreach (var claim in emp.Claims)
                                {
                                    <span class="badge bg-info text-dark me-1">@claim</span>
                                }
                            </td>
                            <td>@(emp.Department ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer small text-muted">Adgangskode for alle: <code>Password123!</code></div>
    </div>
}

</div>
