@* UC-009 - Audit history page: shows chronological list of system changes with filter and details modal *@

@layout DashboardLayout
@page "/audit"
@rendermode InteractiveAuto
@using Core.DTOs.Audit
@using WebUI.Client.Components.Layout

<PageTitle>Historik</PageTitle>

<section aria-label="Audit history" class="container-fluid p-3">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Historik</h2>
    <a href="/dashboard" class="btn btn-outline-secondary btn-sm">
      &larr; Tilbage til dashboard
    </a>
  </div>

  @* Filter bar *@
  <div class="card mb-3">
    <div class="card-body py-2">
      <div class="row g-2 align-items-center">
        <div class="col-12 col-md-5">
          <label for="entityFilter" class="form-label small mb-1">Filtrer på type</label>
          <select id="entityFilter" class="form-select form-select-sm" value="@_selectedEntity"
                  @onchange="OnEntityFilterChanged">
            <option value="">Alle typer</option>
            @foreach (string option in EntityOptions)
            {
              <option value="@option">@option</option>
            }
          </select>
        </div>
        <div class="col-12 col-md-3">
          <label for="limitInput" class="form-label small mb-1">Maks antal (kun "Alle typer")</label>
          <input id="limitInput" type="number" min="1" max="500" class="form-control form-control-sm" value="@_limit"
                 @onchange="OnLimitChanged" disabled="@(!string.IsNullOrEmpty(_selectedEntity))" />
        </div>
        <div class="col-12 col-md-4 text-md-end">
          <button type="button" class="btn btn-sm btn-outline-primary" @onclick="LoadEntriesAsync"
                  disabled="@_isLoading">
            Genindlæs
          </button>
        </div>
      </div>
    </div>
  </div>

  @* Result list *@
  <div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
      <strong>Hændelser</strong>
      <span class="badge bg-secondary">@_entries.Count() poster</span>
    </div>
    <div class="card-body p-0">
      @if (_isLoading)
      {
        <div class="d-flex justify-content-center align-items-center p-4">
          <div class="spinner-border spinner-border-sm text-secondary me-2" role="status">
            <span class="visually-hidden">Indlæser...</span>
          </div>
          <span>Indlæser hændelser...</span>
        </div>
      }
      else if (_hasError)
      {
        <div class="alert alert-warning m-2 py-2 px-3 small mb-0" role="alert">
          Kunne ikke hente historik. Pr&oslash;v at genindlæse.
        </div>
      }
      else if (!_entries.Any())
      {
        <div class="text-muted text-center p-4 small">
          Ingen hændelser fundet for det valgte filter.
        </div>
      }
      else
      {
        <div class="table-responsive">
          <table class="table table-sm table-striped table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th scope="col" class="text-nowrap">Tidspunkt</th>
                <th scope="col">Type</th>
                <th scope="col">Ændring</th>
                <th scope="col">Beskrivelse</th>
                <th scope="col">Bruger</th>
                <th scope="col" class="text-end">Handling</th>
              </tr>
            </thead>
            <tbody>
              @foreach (AuditEntryDto entry in _entries)
              {
                <tr>
                  <td class="text-nowrap small">
                    @entry.EventTimeUtc.ToLocalTime().ToString("dd-MM-yyyy HH:mm:ss")
                  </td>
                  <td class="fw-semibold">@entry.Entity</td>
                  <td>
                    <span class="@GetBadgeClass(entry.ChangeType)">@entry.ChangeType</span>
                  </td>
                  <td class="small">@entry.Description</td>
                  <td class="small text-muted">
                    @(string.IsNullOrEmpty(entry.UserName) ? "—" : entry.UserName)
                  </td>
                  <td class="text-end">
                    <button type="button" class="btn btn-outline-primary btn-sm"
                            @onclick="() => ShowDetailsAsync(entry.Id)">
                      Detaljer
                    </button>
                  </td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      }
    </div>
  </div>
</section>

@* Change-details modal *@
@if (_selectedEntry is not null || _isLoadingDetails)
{
  <div class="modal fade show d-block" tabindex="-1" role="dialog" style="background-color: rgba(0,0,0,0.5);">
    <div class="modal-dialog modal-lg modal-dialog-scrollable" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Detaljer for hændelse</h5>
          <button type="button" class="btn-close" aria-label="Luk" @onclick="CloseDetails"></button>
        </div>
        <div class="modal-body">
          @if (_isLoadingDetails)
          {
            <div class="d-flex justify-content-center p-3">
              <div class="spinner-border spinner-border-sm text-secondary" role="status">
                <span class="visually-hidden">Indlæser...</span>
              </div>
            </div>
          }
          else if (_selectedEntry is not null)
          {
            <dl class="row small mb-3">
              <dt class="col-sm-3">Tidspunkt</dt>
              <dd class="col-sm-9">@_selectedEntry.EventTimeUtc.ToLocalTime().ToString("dd-MM-yyyy HH:mm:ss")</dd>

              <dt class="col-sm-3">Type</dt>
              <dd class="col-sm-9">@_selectedEntry.Entity</dd>

              <dt class="col-sm-3">Ændring</dt>
              <dd class="col-sm-9">
                <span class="@GetBadgeClass(_selectedEntry.ChangeType)">@_selectedEntry.ChangeType</span>
              </dd>

              <dt class="col-sm-3">Beskrivelse</dt>
              <dd class="col-sm-9">@_selectedEntry.Description</dd>

              <dt class="col-sm-3">Bruger</dt>
              <dd class="col-sm-9">
                @(string.IsNullOrEmpty(_selectedEntry.UserName) ? "—" : _selectedEntry.UserName)
              </dd>
            </dl>

            <h6 class="mt-3">Felt-ændringer</h6>
            @if (_selectedEntry.ChangeDetails is null || !_selectedEntry.ChangeDetails.Any())
            {
              <p class="text-muted small mb-0">Ingen felt-ændringer registreret for denne hændelse.</p>
            }
            else
            {
              <table class="table table-sm table-bordered small mb-0">
                <thead class="table-light">
                  <tr>
                    <th scope="col">Felt</th>
                    <th scope="col">Gammel værdi</th>
                    <th scope="col">Ny værdi</th>
                  </tr>
                </thead>
                <tbody>
                  @foreach (ChangeDetailDto detail in _selectedEntry.ChangeDetails)
                  {
                    <tr>
                      <td class="fw-semibold">@detail.Field</td>
                      <td class="text-muted">@(detail.OldValue ?? "—")</td>
                      <td>@(detail.NewValue ?? "—")</td>
                    </tr>
                  }
                </tbody>
              </table>
            }
          }
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary btn-sm" @onclick="CloseDetails">Luk</button>
        </div>
      </div>
    </div>
  </div>
}
