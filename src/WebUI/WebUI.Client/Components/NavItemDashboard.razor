@if (_isLoading)
{
  <div class="text-center py-3">
    <div class="spinner-border text-primary" role="status">
      <span class="visually-hidden">Indlæser...</span>
    </div>
  </div>
}
else if (!string.IsNullOrEmpty(_errorMsg))
{
  <div class="alert alert-danger" role="alert">
    Der opstod en fejl ved indlæsning af dashboard links. Prøv igen.
  </div>
}
else
{
  @if (dashboardLinks.Any())
  {
    <li class="nav-item dropdown">
      <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
        Dashboard
      </a>
      <ul class="dropdown-menu">
        @foreach (var link in dashboardLinks)
        {
          <li>
            <NavLink class="dropdown-item" href="@link.Url" Match="NavLinkMatch.All">@link.Label</NavLink>
          </li>
        }
      </ul>
    </li>
  }
}
